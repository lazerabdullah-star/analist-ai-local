# Bu dosyayı kopyalayıp .env olarak kaydedin
# cp .env.example .env

# Google Gemini API anahtarı (https://aistudio.google.com)
GEMINI_API_KEY=buraya_gemini_anahtarini_yaz

# Google Places API anahtarı (https://console.cloud.google.com)
GOOGLE_PLACES_API_KEY=buraya_places_anahtarini_yaz

# Google OAuth (müşteri Google İşletme Profili bağlantısı, https://console.cloud.google.com)
GOOGLE_OAUTH_CLIENT_ID=buraya_client_id_yaz
GOOGLE_OAUTH_CLIENT_SECRET=buraya_client_secret_yaz
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/musteri/google/callback
GOOGLE_OAUTH_STATE_SECRET=rastgele_bir_gizli_deger_uret
FRONTEND_URL=http://localhost:5173
